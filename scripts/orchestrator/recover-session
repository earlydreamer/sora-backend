#!/bin/bash
# recover-session: Validate and recover orchestration state

set -euo pipefail

source "$(dirname "$0")/lib.sh"

usage() {
  cat <<EOF
Usage: recover-session [OPTIONS]

Validate .orchestrator state against actual tmux windows and normalize.

Options:
  --auto-fix          Automatically fix state mismatches; also auto-retries
                      failed workers when retry_count < max_retries
  --help              Show this help message

EOF
}

auto_fix=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --auto-fix)
      auto_fix=1
      shift
      ;;
    --help)
      usage
      exit 0
      ;;
    *)
      log_error "Unknown option: $1"
      usage
      exit 1
      ;;
  esac
done

ensure_dirs
init_state

log_info "Starting session recovery..."

# Check tmux session exists before querying windows [C6]
# A missing session is not the same as workers being stale — don't damage JSON
if ! tmux_session_exists; then
  log_warn "tmux session '${SESSION_NAME}' not found — cannot validate window state"
  log_warn "Start the tmux session first, then re-run recover-session"
  exit 1
fi

# Get actual tmux windows
mapfile -t actual_windows < <(tmux list-windows -t "${SESSION_NAME}" -F "#{window_name}" 2>/dev/null || true)

# Check registered workers
issues=0
for worker_file in "${WORKERS_DIR}"/worker-*.json; do
  if [ ! -f "$worker_file" ]; then
    continue
  fi

  # Validate JSON before reading [M2]
  if ! validate_worker_json "$worker_file"; then
    log_warn "Skipping corrupt worker file: $worker_file"
    ((issues++))
    continue
  fi

  worker_id=$(jq -r '.worker_id' "$worker_file")
  window_name=$(jq -r '.tmux_window' "$worker_file")
  status=$(jq -r '.status' "$worker_file")

  # Check if window exists
  window_found=0
  for actual_window in "${actual_windows[@]}"; do
    if [ "$actual_window" = "$window_name" ]; then
      window_found=1
      break
    fi
  done

  if [ $window_found -eq 0 ]; then
    log_warn "Window missing for ${worker_id} (${window_name})"
    ((issues++))

    if [ $auto_fix -eq 1 ]; then
      # Mark as stale
      tmp_json=$(mktemp)
      jq '.status = "stale"' "$worker_file" > "$tmp_json"
      mv "$tmp_json" "$worker_file"
      log_info "Marked ${worker_id} as stale"
    fi
  fi

  # Auto-retry failed workers when retry_count < max_retries [C3]
  # Update existing worker JSON to 'retrying' instead of spawning a new worker
  if [ $auto_fix -eq 1 ] && [ "$status" = "failed" ]; then
    retry_count=$(jq -r '.retry_count // 0' "$worker_file" 2>/dev/null)
    wmax_retries=$(jq -r '.max_retries // 0' "$worker_file" 2>/dev/null)
    if [ "$wmax_retries" -gt 0 ] && [ "$retry_count" -lt "$wmax_retries" ]; then
      new_retry_count=$((retry_count + 1))
      log_info "Auto-retrying ${worker_id} (retry ${new_retry_count}/${wmax_retries})"

      # Re-spawn using same parameters — new window for this attempt
      w_agent=$(jq -r '.agent' "$worker_file")
      w_task_ref=$(jq -r '.task_ref' "$worker_file")
      w_spec_path=$(jq -r '.spec_path // ""' "$worker_file")
      w_slug=$(echo "${window_name}" | sed "s/^${worker_id}-${w_agent}-//")

      spawn_args=("$w_agent" "$w_slug" "$w_task_ref" "--retry" "$wmax_retries")
      if [ -n "$w_spec_path" ]; then
        spawn_args+=(--spec "$w_spec_path")
      fi

      # Mark existing record as 'retrying' before spawning replacement [C3]
      tmp_json=$(mktemp)
      jq --argjson rc "$new_retry_count" \
         --arg ts "$(iso8601_now)" \
         '.status = "retrying" | .retry_count = $rc | .last_heartbeat = $ts' \
         "$worker_file" > "$tmp_json"
      mv "$tmp_json" "$worker_file"

      "$(dirname "$0")/spawn-worker" "${spawn_args[@]}"
      log_success "Spawned replacement for ${worker_id}"
    fi
  fi
done

log_info "Recovery check complete: ${issues} issues found"

if [ $issues -eq 0 ]; then
  log_success "Session state is healthy"
  exit 0
else
  log_warn "Run with --auto-fix to normalize issues"
  exit 1
fi
