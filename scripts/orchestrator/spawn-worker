#!/bin/bash
# spawn-worker: Create new tmux window for a worker agent

set -euo pipefail

source "$(dirname "$0")/lib.sh"

usage() {
  cat <<EOF
Usage: spawn-worker [OPTIONS] <agent> <slug> <task-ref>

Create a new tmux window and register a worker.

Arguments:
  agent           Agent type: codex, gemini, etc.
  slug            Brief slug for the task (e.g., routes, auth)
  task-ref        Task reference or spec path (e.g., task-1, docs/tasks/2026-03-31-routes.md)

Options:
  --spec FILE          Path to task specification file
  --auto-start         Automatically start the agent with task command
  --command CMD        Initial command to send to the window
  --split-log          Split window: main pane (70%) + log pane (30%, tail -f)
  --retry N            Set max retries (adds retry_count/max_retries to worker JSON)
  --from-queue         Read next item from .orchestrator/queue.json (ignores positional args)
  --help               Show this help message

Examples:
  spawn-worker codex routes task-1
  spawn-worker codex routes task-1 --spec docs/tasks/2026-03-31-routes.md --auto-start
  spawn-worker codex auth auth-impl --command "npm run build && npm run lint"
  spawn-worker codex routes task-1 --split-log --retry 3
  spawn-worker --from-queue

EOF
}

# Parse arguments
agent=""
slug=""
task_ref=""
spec_file=""
auto_start=0
initial_command=""
split_log=0
max_retries=0
initial_retry_count=0
use_retry=0
from_queue=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --spec)
      spec_file="$2"
      shift 2
      ;;
    --auto-start)
      auto_start=1
      shift
      ;;
    --command)
      initial_command="$2"
      shift 2
      ;;
    --split-log)
      split_log=1
      shift
      ;;
    --retry)
      max_retries="$2"
      use_retry=1
      shift 2
      ;;
    --retry-count)
      initial_retry_count="$2"
      shift 2
      ;;
    --from-queue)
      from_queue=1
      shift
      ;;
    --help)
      usage
      exit 0
      ;;
    -*)
      log_error "Unknown option: $1"
      usage
      exit 1
      ;;
    *)
      if [ -z "$agent" ]; then
        agent="$1"
      elif [ -z "$slug" ]; then
        slug="$1"
      elif [ -z "$task_ref" ]; then
        task_ref="$1"
      else
        log_error "Too many positional arguments"
        usage
        exit 1
      fi
      shift
      ;;
  esac
done

# Setup directories first (needed for queue_pop)
ensure_dirs
init_state

# --from-queue: pop next item from queue
# If tmux creation later fails, push the item back [C4]
queue_item_backup=""
if [ $from_queue -eq 1 ]; then
  queue_item=$(queue_pop) || { log_error "Failed to pop from queue"; exit 1; }
  queue_item_backup="$queue_item"
  agent=$(echo "$queue_item" | jq -r '.agent')
  slug=$(echo "$queue_item" | jq -r '.slug')
  task_ref=$(echo "$queue_item" | jq -r '.task_ref')
  spec_file=$(echo "$queue_item" | jq -r '.spec_path // ""')
  _q_priority=$(echo "$queue_item" | jq -r '.priority // 5')
  log_info "Loaded from queue: agent=${agent} slug=${slug} task_ref=${task_ref}"
fi

# Validate required arguments
if [ -z "$agent" ] || [ -z "$slug" ] || [ -z "$task_ref" ]; then
  log_error "Missing required arguments"
  usage
  exit 1
fi

# Generate worker ID — window_name does NOT re-prefix worker_id [C1]
worker_id=$(next_worker_id)
window_name="${worker_id}-${agent}-${slug}"
log_file="${LOGS_DIR}/${worker_id}.log"
worker_json="${WORKERS_DIR}/${worker_id}.json"

# Create tmux window — restore queue item on failure [C4]
log_info "Creating tmux window: ${window_name}"
if ! tmux new-window -t "${SESSION_NAME}" -n "${window_name}" -d -c "${REPO_ROOT}" 2>/dev/null; then
  if [ -n "$queue_item_backup" ]; then
    queue_push \
      "$(echo "$queue_item_backup" | jq -r '.agent')" \
      "$(echo "$queue_item_backup" | jq -r '.slug')" \
      "$(echo "$queue_item_backup" | jq -r '.task_ref')" \
      "$(echo "$queue_item_backup" | jq -r '.spec_path // ""')" \
      "$_q_priority"
    log_warn "Restored queue item after tmux failure"
  fi
  log_error "Failed to create tmux window: ${window_name}"
  exit 1
fi
tmux set-window-option -t "${SESSION_NAME}:${window_name}" remain-on-exit on

# --split-log: split window into main pane (70%) and log pane (30%) [H1]
# After split, pane 1 (bottom) is active — explicitly send commands to pane 0 (top/main)
if [ $split_log -eq 1 ]; then
  log_info "Splitting window for log pane"
  tmux split-window -t "${SESSION_NAME}:${window_name}.0" -v -p 30 -c "${REPO_ROOT}"
  tmux send-keys -t "${SESSION_NAME}:${window_name}.1" "tail -f '${log_file}'" Enter
fi

# Create worker JSON using jq --arg to safely handle special characters in values [L1]
log_info "Registering worker: ${worker_id}"
if [ $use_retry -eq 1 ]; then
  jq -n \
    --arg worker_id "${worker_id}" \
    --arg agent "${agent}" \
    --arg tmux_window "${window_name}" \
    --arg task_ref "${task_ref}" \
    --arg spec_path "${spec_file}" \
    --arg log_path "${log_file}" \
    --arg ts "$(iso8601_now)" \
    --argjson max_retries "${max_retries}" \
    --argjson initial_retry_count "${initial_retry_count}" \
    '{
      worker_id: $worker_id,
      agent: $agent,
      tmux_window: $tmux_window,
      status: "starting",
      task_ref: $task_ref,
      spec_path: $spec_path,
      log_path: $log_path,
      started_at: $ts,
      last_heartbeat: $ts,
      last_output_at: null,
      owner: "controller",
      retry_count: $initial_retry_count,
      max_retries: $max_retries
    }' > "${worker_json}"
else
  jq -n \
    --arg worker_id "${worker_id}" \
    --arg agent "${agent}" \
    --arg tmux_window "${window_name}" \
    --arg task_ref "${task_ref}" \
    --arg spec_path "${spec_file}" \
    --arg log_path "${log_file}" \
    --arg ts "$(iso8601_now)" \
    '{
      worker_id: $worker_id,
      agent: $agent,
      tmux_window: $tmux_window,
      status: "starting",
      task_ref: $task_ref,
      spec_path: $spec_path,
      log_path: $log_path,
      started_at: $ts,
      last_heartbeat: $ts,
      last_output_at: null,
      owner: "controller"
    }' > "${worker_json}"
fi

# Update state.json workers[] array [C5]
local_tmp=$(mktemp)
jq --arg wid "${worker_id}" \
   --arg agent "${agent}" \
   --arg window "${window_name}" \
   '.workers += [{worker_id: $wid, agent: $agent, tmux_window: $window, status: "starting"}]' \
   "${STATE_FILE}" > "$local_tmp"
mv "$local_tmp" "${STATE_FILE}"

# Prepare initial command
if [ $auto_start -eq 1 ]; then
  # Auto-start mode: build agent-specific command
  task_desc="${task_ref}를 읽고 구현해줘"
  [ -n "$spec_file" ] && task_desc="${spec_file}를 읽고 구현해줘"
  # Write task description to a separate file to avoid any quote injection
  # in the cmd_script when task_desc contains special characters.
  task_desc_file="${LOGS_DIR}/${worker_id}-task.txt"
  printf '%s\n' "${task_desc}" > "${task_desc_file}"
  case "$agent" in
    codex)
      initial_command="cd \"${REPO_ROOT}\" && codex exec - < \"${task_desc_file}\""
      ;;
    *)
      initial_command="cd \"${REPO_ROOT}\" && claude \"\$(cat '${task_desc_file}')\""
      ;;
  esac
  log_info "Auto-start enabled: will inject ${agent} command"
elif [ -n "$initial_command" ]; then
  log_info "Custom command: ${initial_command}"
fi

# Send initial command to pane 0 (main worker pane) [H1b]
# Write to a temp script to avoid tmux send-keys quoting issues entirely.
if [ -n "$initial_command" ]; then
  log_info "Sending initial command to window pane 0"
  cmd_script="${LOGS_DIR}/${worker_id}-cmd.sh"
  printf '#!/bin/bash\n' > "$cmd_script"
  printf '%s\n' "$initial_command" >> "$cmd_script"
  chmod +x "$cmd_script"
  if [ $split_log -eq 1 ]; then
    # Wrap with tee so output also goes to log file [H1a]
    tmux send-keys -t "${SESSION_NAME}:${window_name}.0" "bash '${cmd_script}' 2>&1 | tee -a '${log_file}'" Enter
  else
    tmux send-keys -t "${SESSION_NAME}:${window_name}.0" "bash '${cmd_script}'" Enter
  fi
fi

# Log the spawn event
echo "[$(date +'%Y-%m-%d %H:%M:%S')] Worker spawned: ${worker_id} (${agent}/${slug})" >> "${log_file}"

log_success "Worker spawned: ${worker_id}"
log_info "Window: ${SESSION_NAME}:${window_name}"
log_info "Log: ${log_file}"
log_info "State: ${worker_json}"

# Optional: Print JSON output for automation
if [ "${OUTPUT_JSON:-0}" = "1" ]; then
  cat "${worker_json}"
fi
